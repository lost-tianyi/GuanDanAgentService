# =============================================================================
# 掼蛋服务端环境变量示例
# - 复制本文件为 server 目录下的 .env 后按需取消注释并填写
# - 勿将含真实密钥的 .env 提交到 Git
# - 条目含义与默认值详见 src/config/env.ts 顶部中文说明
# =============================================================================

# --- 一、HTTP 服务 ---
# 监听端口（默认 3001）
# PORT=3001

# --- 二、OpenAI 兼容 API（教练等）---
# 密钥，教练调用 LLM 必填
# OPENAI_API_KEY=
# API 根地址，无尾斜杠（默认见 server.defaults.ts）
# OPENAI_API_BASE=https://api.moonshot.cn/v1

# --- 三、教练（Coach）---
# 是否允许请求教练提示；设为 false 关闭
# COACH_HINT_ENABLED=true
# 是否调用大模型；设为 false 仅用本地兜底文案
# COACH_USE_LLM=true
# 是否流式输出思路；设为 false 改单次请求
# COACH_USE_STREAM=true
# 模型 ID（覆盖默认 kimi-k2.5）
# COACH_OPENAI_MODEL=kimi-k2.5
# 请求超时毫秒（默认 25000）
# COACH_REASON_TIMEOUT_MS=25000
# 非 Kimi K2 时的 temperature；不填则用代码内默认约 0.58
# COACH_OPENAI_TEMPERATURE=0.58
# 非流式时是否请求 JSON 模式（依赖供应商）
# COACH_OPENAI_JSON_MODE=false
# 非空时：浏览器须先通过 Socket 事件 unlock-coach 提交正确密码，才允许请求教练（与 OPENAI_API_KEY 一样用 Docker 环境变量注入）
# COACH_UNLOCK_PASSWORD=
